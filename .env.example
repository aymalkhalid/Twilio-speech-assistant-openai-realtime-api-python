# Copy to .env and set your values.

OPENAI_API_KEY=
PORT=5050
COMPANY_NAME=Acme Voice Agent Demo
AGENT_NAME=
AGENT_LABEL=generic_voice_agent
SYSTEM_INSTRUCTIONS_PATH=prompts/main_system_instructions.md

OPENAI_REALTIME_MODEL=gpt-realtime-2
REALTIME_REASONING_EFFORT=low
VOICE=cedar
ASSISTANT_LANGUAGE=English
ASSISTANT_ACCENT=neutral American
ASSISTANT_ACCENT_STRENGTH=light
# default_only keeps English as the primary response language; change accent with ASSISTANT_ACCENT.
# Use explicit_or_substantive to allow switching when the caller clearly uses another language.
LANGUAGE_SWITCH_POLICY=default_only

# Optional call-record storage/dashboard. Core calls can run without Supabase.
CALL_RECORD_BACKEND=webhook
WEBHOOK_URL=
WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_CALL_RECORD_TABLE=call_records

# Optional Google Calendar booking.
BOOKING_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_CREDENTIALS_JSON=
BOOKING_SLOT_DURATION_MINUTES=60
BUSINESS_APPOINTMENT_OPENING_TIME=08:00
BUSINESS_APPOINTMENT_CLOSING_TIME=18:00
BOOKING_DAYS_ENABLED=

# Optional call recording and transcript generation.
CALL_RECORDING_ENABLED=false
RECORDING_STATUS_CALLBACK_BASE_URL=
TRANSCRIPTION_MODEL=tiny
TRANSCRIPT_ENHANCEMENT_ENABLED=true
TRANSCRIPT_ENHANCEMENT_MODE=manual
TRANSCRIPT_ENHANCEMENT_MODEL=gpt-4o-mini

# Twilio credentials are required for REST hangup, recording, transfer, and outbound calls.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional live transfer to a human agent.
HUMAN_TRANSFER_URL=
HUMAN_TRANSFER_ENABLED=true
HUMAN_TRANSFER_DIAL_NUMBER=+15551234567

# Optional dashboard auth. Format: user1:pass1,user2:pass2
DASHBOARD_USERS=

# Optional outbound calling.
OUTBOUND_ENABLED=false
TWILIO_OUTBOUND_NUMBER=
OUTBOUND_MAX_CONCURRENCY=3
OUTBOUND_BASE_URL=
SUPABASE_OUTBOUND_CAMPAIGNS_TABLE=outbound_campaigns
SUPABASE_OUTBOUND_CONTACTS_TABLE=outbound_contacts

# MCP scaffold is disabled in v1. Add a real adapter before enabling external tools.
MCP_ENABLED=false
